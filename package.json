{
  "name": "apayshop",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "nuxt build",
    "build-pg": "unset DATABASE_URL && DB_DIALECT=postgresql yarn build",
    "dev": "nuxt dev --env-file=.env --port 5400",
    "generate": "nuxt generate",
    "preview": "nuxt preview --port 5400",
    "postinstall": "nuxt prepare",
    "deploy": "nuxi build --preset cloudflare-pages && wrangler pages deploy dist && npx wrangler d1 migrations apply apayshop --remote",
    "migrate": "drizzle-kit migrate",
    "db:pg:gen": "drizzle-kit generate --config=drizzle.pg.config.ts",
    "db:pg:push": "drizzle-kit push --config=drizzle.pg.config.ts",
    "db:pg:migrate": "drizzle-kit migrate --config=drizzle.pg.config.ts",
    "db:gen": "drizzle-kit generate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@nuxt/content": "^2.13.4",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/ui": "^4.6.0",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/vue-3": "^3.21.0",
    "@vueuse/integrations": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "^0.5.29",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "sortablejs": "^1.15.7",
    "vuedraggable": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/i18n": "^9.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.78.0"
  }
}
